inders-section {\n    margin-top: 24px;\n  }\n  .section-title {\n    color: #242424;\n    font-size: 15.88px;\n    font-family: 'Inter', sans-serif;\n    font-weight: 500;\n    line-height: 22px;\n    margin-bottom: 8px;\n  }\n  .reminder-item {\n    display: flex;\n    align-items: flex-start;\n    gap: 10px;\n    margin-bottom: 16px;\n  }\n  .reminder-dot {\n    width: 8px;\n    height: 8px;\n    min-width: 8px;\n    background: #006340;\n    border-radius: 9999px;\n    margin-top: 8px;\n  }\n  .reminder-text {\n    color: #1A202C;\n    font-size: 14px;\n    font-family: 'Inter', sans-serif;\n    font-weight: 400;\n    line-height: 24px;\n    letter-spacing: 0.06px;\n  }\n\n  .share-section {\n    margin-top: 32px;\n    margin-bottom: 24px;\n  }\n  .share-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 0;\n  }\n  .share-btn {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    height: 36px;\n    margin: 4px;\n    border-radius: 100px;\n    border: 1px solid #0F0F0F;\n    background: none;\n    cursor: pointer;\n    font-size: 14px;\n    font-family: 'Inter', sans-serif;\n    font-weight: 400;\n    color: #242424;\n    line-height: 19.25px;\n    letter-spacing: 0.06px;\n    -webkit-tap-highlight-color: transparent;\n  }\n  .share-btn:active {\n    transform: scale(0.97);\n  }\n  .share-btn svg {\n    width: 16px;\n    height: 16px;\n    flex-shrink: 0;\n  }\n\n  .footer {\n    position: sticky;\n    bottom: 0;\n    background: white;\n    border-top: 2px solid #CFCFCF;\n    box-shadow: 0px 4px 6px -2px rgba(0,0,0,0.05), 0px 10px 15px -3px rgba(0,0,0,0.10);\n    padding: 16px;\n  }\n  .btn-continue {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 100%;\n    height: 42px;\n    background: #006340;\n    color: white;\n    border: none;\n    border-radius: 100px;\n    font-size: 16px;\n    font-family: 'Inter', sans-serif;\n    font-weight: 600;\n    l